# ============================================================
# Supabase Configuration
# ============================================================
# URL do seu projeto Supabase
SUPABASE_URL=https://your-project-id.supabase.co

# Service Role Key — use APENAS no backend, nunca exponha no frontend
# Encontre em: Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================================
# OpenAI — para geração da resposta final
# ============================================================
OPENAI_API_KEY=sk-your-openai-api-key-here

# ============================================================
# Modelo de Embedding (local, via @xenova/transformers)
# IMPORTANTE: deve ser o mesmo modelo usado para popular a tabela.
# A tabela `biia` usa vector(384) → Xenova/all-MiniLM-L6-v2
# O modelo é baixado automaticamente na primeira execução (~90 MB)
# ============================================================
EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2

# ============================================================
# Modelo LLM para a resposta final
# Opções: gpt-5.4 | gpt-5.4-mini | gpt-5.4-nano
# ============================================================
CHAT_MODEL=gpt-5.4

# ============================================================
# Configuração do RAG (Supabase)
# ============================================================
# Nome da função RPC criada em supabase/match_biia.sql
RPC_FUNCTION=match_biia

# Quantos resultados similares recuperar da tabela
MATCH_COUNT=5

# Score mínimo de similaridade (0.0 a 1.0)
# Resultados abaixo deste valor são descartados (evita contexto irrelevante)
# 0.5 é um bom ponto de partida; aumente para respostas mais conservadoras
SIMILARITY_THRESHOLD=0.5

# ============================================================
# Servidor
# ============================================================
PORT=3000
